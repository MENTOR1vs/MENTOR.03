# PostgreSQL container configuration

POSTGRES_DB=mentor_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=123456

# API database connection

# Docker service name used by the API to reach PostgreSQL.
DB_HOST=db
# Internal PostgreSQL port.
DB_PORT=5432

DB_NAME=mentor_db
DB_USER=admin
DB_PASSWORD=123456

# Application ports and client origin

API_PORT=3000
CLIENT_PORT=5173

# Frontend origin allowed by the API through CORS.

CLIENT_ORIGIN=http://localhost:5173

# Authentication configuration

# Replace this value with a long random secret in production.
JWT_SECRET=replace_this_with_a_long_secret
# Duration of the JSON Web Token session.
JWT_EXPIRES_IN=8h
#Name of the HttpOnly cookie that stores the session token
COOKIE_NAME=mentor_session

NODE_ENV=development

#Default admin account 
ADMIN_EMAIL=admin@mentor.test
ADMIN_PASSWORD=123456

#pgAdmin credentials

PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
